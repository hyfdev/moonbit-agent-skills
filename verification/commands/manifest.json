    {
      "id": "conditional-targets",
      "setup": "template",
      "run": [
        "mkdir -p cmd/show",
        "cat > cmd/show/moon.pkg <<'MBTEOF'\npkgtype(kind: \"executable\")\n\noptions(\n  targets: {\n    \"only_js.mbt\": [ \"js\" ],\n    \"not_js.mbt\": [ \"not\", \"js\" ],\n  },\n)\nMBTEOF",
        "cat > cmd/show/only_js.mbt <<'MBTEOF'\n///|\npub fn backend_tag() -> String {\n  \"js backend\"\n}\n\n///|\nfn main {\n  println(backend_tag())\n}\nMBTEOF",
        "cat > cmd/show/not_js.mbt <<'MBTEOF'\n///|\npub fn backend_tag() -> String {\n  \"non-js backend\"\n}\n\n///|\nfn main {\n  println(backend_tag())\n}\nMBTEOF",
        "moon run cmd/show",
        "moon run --target js cmd/show"
      ],
      "expect_exit": 0,
      "expect_output_contains": [
        "js backend"
      ],
      "docs": [
        "targets-and-conditional-builds.md"
