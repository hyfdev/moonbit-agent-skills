    {
      "id": "registry-publish",
      "documented_only": true,
      "commands": [
        "moon publish",
        "moon publish --dry-run"
      ],
      "reason": "Publishes to (and authenticates against) the mooncakes registry. Verified manually at the pin that even --dry-run contacts the server after the local pipeline (403 user-mismatch response proves the round-trip); never run in CI."
    },
    {
      "id": "registry-login",
      "documented_only": true,
      "commands": [
        "moon login"
      ],
      "reason": "Account-level command: stores registry credentials in the global moon home; must not run in CI."
    },
    {
      "id": "registry-register",
      "documented_only": true,
      "commands": [
        "moon register"
      ],
      "reason": "Creates a mooncakes.io account (remote, irreversible); must not run in CI."
    },
    {
      "id": "install-global",
      "documented_only": true,
      "commands": [
        "moon install username/module"
      ],
      "reason": "Installs a binary globally into the toolchain home, outside the CI working directory; networky and not sandboxed by the temp workdir."
    }
  ]
